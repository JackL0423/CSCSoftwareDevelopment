# GlobalFlavors Environment Variables Template
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in the actual values in .env (NEVER commit .env to git!)
# 3. Use the provided script to store secrets in Google Secret Manager
# 4. Delete .env after storing: shred -u .env
#
# ⚠️ NEVER commit .env with real values to git!
# ✅ This .env.example file is safe to commit (contains no real secrets)

# =============================================================================
# FLUTTERFLOW API
# =============================================================================
# Get from: https://app.flutterflow.io/account
# Required for: Project API access, YAML updates, project queries
FLUTTERFLOW_API_TOKEN=your_flutterflow_token_here

# =============================================================================
# FIGMA API
# =============================================================================
# Get from: Figma Settings → Personal Access Tokens
# Required for: Reading design files, extracting tokens, validating exports
FIGMA_API_KEY=your_figma_api_key_here

# FlutterFlow Project ID (from API response)
# Format: project-name-abc123
FLUTTERFLOW_PROJECT_ID=c-s-c305-capstone-khj14l

# Figma File ID (from file URL)
# URL format: https://figma.com/file/FILE_ID/...
FIGMA_FILE_ID=your_figma_file_id_here

# =============================================================================
# FIREBASE (Future Use)
# =============================================================================
# These will be needed when configuring Firebase authentication
# Get from: Firebase Console → Project Settings → Service Accounts

# Firebase Project ID
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# Firebase Web API Key
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here

# Firebase Service Account Key (JSON file path - do NOT commit the JSON!)
# Store the actual JSON file separately in Google Secret Manager
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# =============================================================================
# GOOGLE CLOUD PROJECT
# =============================================================================
# Your GCP project for Secret Manager
GCP_PROJECT_ID=your_gcp_project_id_here

# Service Account Email (if using service account auth)
GCP_SERVICE_ACCOUNT_EMAIL=your-service@project.iam.gserviceaccount.com

# =============================================================================
# THIRD-PARTY INTEGRATIONS (Future)
# =============================================================================
# Instacart API (for grocery cart integration)
INSTACART_API_KEY=your_instacart_key_here
INSTACART_CLIENT_ID=your_instacart_client_id_here

# Walmart API (for grocery integration)
WALMART_API_KEY=your_walmart_key_here
WALMART_CLIENT_ID=your_walmart_client_id_here

# Amazon Fresh Affiliate ID
AMAZON_AFFILIATE_ID=your_amazon_affiliate_id_here

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Environment: development | staging | production
NODE_ENV=development

# API Base URLs (override for testing)
FLUTTERFLOW_API_BASE_URL=https://api.flutterflow.io/v2
FIGMA_API_BASE_URL=https://api.figma.com/v1

# Debug mode (true/false)
DEBUG=true

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# =============================================================================
# TEAM MEMBER EMAILS (for access control)
# =============================================================================
# School team email
TEAM_EMAIL=uricsc305@gmail.com

# Team members
TEAM_MEMBER_1=john.light@uri.edu
TEAM_MEMBER_2=mariamillington@uri.edu
TEAM_MEMBER_3=alexander.hang@uri.edu
TEAM_MEMBER_4=sophia.dellaselva@uri.edu
TEAM_MEMBER_5=Juan_vallejo@uri.edu

# =============================================================================
# SECURITY & RATE LIMITING
# =============================================================================
# Max API requests per minute (to avoid rate limits)
API_RATE_LIMIT=60

# Request timeout (milliseconds)
API_TIMEOUT=30000

# Retry attempts for failed requests
API_RETRY_ATTEMPTS=3
